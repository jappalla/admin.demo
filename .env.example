APP_NAME="Antonio Trapasso CV"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_BASE_URL=
APP_ROUTE_MODE=path
APP_SEO_TITLE="Antonio Trapasso | Curriculum Vitae"
APP_SEO_DESCRIPTION="Curriculum vitae personale di Antonio Trapasso: esperienza, competenze e contatti professionali."

# ===========================
# DATABASE — Sviluppo (locale)
# ===========================
# Locale: cv_portal_local | Produzione: dnmmbunn_curriculum
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cv_portal_local
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ===========================
# DATABASE — Produzione
# ===========================
# Decommentare e compilare per produzione:
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=dnmmbunn_curriculum
# DB_USERNAME=dnmmbunn_kenzo
# DB_PASSWORD=your_production_password
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci


ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=ChangeMe123!

CONTACT_RECIPIENT_EMAIL=info.databrother@gmail.com
CONTACT_RECIPIENT_NAME="Antonio Trapasso"
CONTACT_SENDER_EMAIL=your-account@gmail.com
CONTACT_SENDER_NAME="Antonio Trapasso"
CONTACT_RETURN_PATH=your-account@gmail.com
CONTACT_AUTOREPLY_ENABLED=true
CONTACT_AUTOREPLY_SUBJECT="Conferma ricezione del tuo messaggio"
CONTACT_AUTOREPLY_RESPONSE_HOURS=24

# Optional SMTP settings (recommended for reliable delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

# Optional dedicated transport for contact form.
# If empty, CONTACT notifier falls back to SMTP_* values above.
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_USER=your-account@gmail.com
CONTACT_SMTP_PASS=your-google-app-password
CONTACT_SMTP_SECURE=ssl
